{
  "name": "tau",
  "version": "1.0.0",
  "private": true,
  "description": "Opinionated workflow governor for pi.",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "build": "echo 'tau: no build step required yet'",
    "changeset": "changeset",
    "changeset:check": "changeset status --since=origin/main",
    "changeset:version": "changeset version",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "dev": "echo 'tau: dev entrypoint not implemented yet'",
    "format": "vp fmt && prettier --write .",
    "format:check": "vp fmt --check && prettier --check .",
    "lint": "vp lint",
    "prepare": "vp config",
    "test": "vitest run --passWithNoTests",
    "typecheck": "node scripts/typecheck.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.5.0",
    "prettier": "3.8.1",
    "typescript": "^6.0.2",
    "vite-plus": "0.1.16",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
